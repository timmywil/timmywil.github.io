{
  "name": "timmywil.com",
  "version": "0.0.1",
  "description": "Personal blog and website for Timmy Willison",
  "main": "index.js",
  "scripts": {
    "commit": "git-cz",
    "release": "semantic-release",
    "start": "bundle exec jekyll serve"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/timmywil/timmywil.com.git"
  },
  "keywords": [
    "timmywil",
    "Timmy",
    "Willison",
    "personal",
    "website",
    "blog"
  ],
  "author": "Timmy Willison <4timmywil@gmail.com>",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/timmywil/timmywil.com/issues"
  },
  "homepage": "https://github.com/timmywil/timmywil.com#readme",
  "devDependencies": {
    "@commitlint/cli": "^7.5.2",
    "@commitlint/config-conventional": "^7.5.0",
    "@commitlint/prompt": "^7.5.0",
    "commitizen": "^3.1.1",
    "husky": "^1.3.1",
    "semantic-release": "^15.13.3"
  },
  "prettier": {
    "printWidth": 100,
    "semi": false,
    "singleQuote": true,
    "jsxBracketSameLine": true,
    "arrowParens": "always"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/@commitlint/prompt"
    }
  },
  "husky": {
    "hooks": {
      "commit-msg": "commitlint -E HUSKY_GIT_PARAMS"
    }
  },
  "release": {
    "branch": "master",
    "ci": false,
    "npmPublish": false,
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/npm",
      "@semantic-release/git",
      "@semantic-release/github"
    ],
    "tagFormat": "${version}"
  }
}
